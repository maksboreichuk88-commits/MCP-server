{
  "admin": {
    "enabled": true,
    "port": 9090,
    "host": "127.0.0.1",
    "corsEnabled": true,
    "corsOrigins": ["*"]
  },
  "cache": {
    "ttlSeconds": 300,
    "alwaysCacheTools": ["read_file", "list_directory", "search_files"],
    "neverCacheTools": ["write_file", "create_file", "execute_command"]
  },
  "verbose": true
}
